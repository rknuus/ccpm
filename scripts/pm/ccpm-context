#!/bin/bash
# ccpm-context — Standalone script for tracking active work item context with timestamped history.
#
# Usage:
#   ccpm-context open <type> <name> <command>   — set active context (auto-closes previous)
#   ccpm-context close                          — close active context, move to history
#   ccpm-context reopen [max_age_minutes]       — reopen last closed context if recent enough
#   ccpm-context history <type> <name>          — output JSON array of history entries to stdout
#
# Environment:
#   STATS_CONTEXT_FILE  — override path to context file (default: .pm/stats/active-context.json)

# Path to the active context file (relative to project root)
STATS_CONTEXT_FILE="${STATS_CONTEXT_FILE:-.pm/stats/active-context.json}"

# Ensure the context file exists with a valid initial structure.
_ensure_file() {
  local dir
  dir="$(dirname "$STATS_CONTEXT_FILE")"
  mkdir -p "$dir" 2>/dev/null || true
  if [ ! -f "$STATS_CONTEXT_FILE" ]; then
    printf '{"current":null,"history":[]}\n' > "$STATS_CONTEXT_FILE" 2>/dev/null || true
  fi
}

cmd_open() {
  local ctx_type="$1" ctx_name="$2" ctx_command="$3"
  if [ -z "$ctx_type" ] || [ -z "$ctx_name" ] || [ -z "$ctx_command" ]; then
    return 0
  fi

  _ensure_file

  local now
  now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  # If there is already an active context, close it first
  local has_current
  has_current="$(jq -r '.current != null' "$STATS_CONTEXT_FILE" 2>/dev/null)"
  if [ "$has_current" = "true" ]; then
    jq --arg ended "$now" \
      '.history += [.current + {ended: $ended}] | .current = null' \
      "$STATS_CONTEXT_FILE" > "${STATS_CONTEXT_FILE}.tmp" 2>/dev/null \
      && mv "${STATS_CONTEXT_FILE}.tmp" "$STATS_CONTEXT_FILE" 2>/dev/null || true
  fi

  # Set the new active context
  jq --arg type "$ctx_type" \
     --arg name "$ctx_name" \
     --arg command "$ctx_command" \
     --arg started "$now" \
     '.current = {type: $type, name: $name, command: $command, started: $started}' \
     "$STATS_CONTEXT_FILE" > "${STATS_CONTEXT_FILE}.tmp" 2>/dev/null \
    && mv "${STATS_CONTEXT_FILE}.tmp" "$STATS_CONTEXT_FILE" 2>/dev/null || true
}

cmd_close() {
  _ensure_file

  local has_current
  has_current="$(jq -r '.current != null' "$STATS_CONTEXT_FILE" 2>/dev/null)"
  if [ "$has_current" != "true" ]; then
    return 0
  fi

  local now
  now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  jq --arg ended "$now" \
    '.history += [.current + {ended: $ended}] | .current = null' \
    "$STATS_CONTEXT_FILE" > "${STATS_CONTEXT_FILE}.tmp" 2>/dev/null \
    && mv "${STATS_CONTEXT_FILE}.tmp" "$STATS_CONTEXT_FILE" 2>/dev/null || true
}

cmd_history() {
  local ctx_type="$1" ctx_name="$2"
  if [ -z "$ctx_type" ] || [ -z "$ctx_name" ]; then
    echo "[]"
    return 0
  fi

  _ensure_file

  jq --arg type "$ctx_type" --arg name "$ctx_name" \
    '[.history[] | select(.type == $type and .name == $name)]' \
    "$STATS_CONTEXT_FILE" 2>/dev/null || echo "[]"
}

cmd_reopen() {
  local max_age_minutes="${1:-30}"

  _ensure_file

  # If there's already an active context, nothing to do
  local has_current
  has_current="$(jq -r '.current != null' "$STATS_CONTEXT_FILE" 2>/dev/null)"
  if [ "$has_current" = "true" ]; then
    return 0
  fi

  # Get the last history entry
  local last_entry
  last_entry="$(jq -r '.history[-1] // empty' "$STATS_CONTEXT_FILE" 2>/dev/null)"
  if [ -z "$last_entry" ]; then
    return 0
  fi

  # Check staleness: compare ended timestamp to now
  local ended_ts
  ended_ts="$(echo "$last_entry" | jq -r '.ended // empty')"
  if [ -z "$ended_ts" ]; then
    return 0
  fi

  local now_epoch ended_epoch
  now_epoch="$(date -u +%s)"
  # macOS date -j -f needs TZ=UTC for Z-suffixed timestamps; GNU date -d handles it
  ended_epoch="$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "$ended_ts" +%s 2>/dev/null \
    || date -d "$ended_ts" +%s 2>/dev/null \
    || echo 0)"

  local age_seconds=$(( now_epoch - ended_epoch ))
  local max_age_seconds=$(( max_age_minutes * 60 ))

  if [ "$age_seconds" -gt "$max_age_seconds" ]; then
    return 0
  fi

  # Reopen with the same type/name but command="followup"
  local ctx_type ctx_name
  ctx_type="$(echo "$last_entry" | jq -r '.type')"
  ctx_name="$(echo "$last_entry" | jq -r '.name')"
  cmd_open "$ctx_type" "$ctx_name" "followup"
}

# Main dispatch
subcmd="${1:-}"
shift 2>/dev/null || true

case "$subcmd" in
  open)    cmd_open "${1:-}" "${2:-}" "${3:-}" ;;
  close)   cmd_close ;;
  reopen)  cmd_reopen "${1:-}" ;;
  history) cmd_history "${1:-}" "${2:-}" ;;
  *)
    echo "Usage: ccpm-context {open|close|reopen|history} [args...]" >&2
    exit 0
    ;;
esac
